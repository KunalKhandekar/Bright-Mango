# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
WEB_APP_URL=http://localhost:3000

# Comma-separated allowlist for CORS (frontend origins)
CORS_ORIGINS=http://localhost:3000,https://app.brightmango.in,https://brightmango.in

# ── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/brightmango

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Sessions / Cookies ──────────────────────────────────
# Secret used to HMAC OTPs (NOT for signing JWTs — we don't use JWT)
OTP_HMAC_SECRET=change-me-long-random-string
COOKIE_NAME=bm_session
COOKIE_DOMAIN=localhost
SESSION_TTL_DAYS=7
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
STUDENT_MAX_SESSIONS=2
TRUSTED_DEVICE_TTL_DAYS=7

# ── Bootstrap mentor (seed) ─────────────────────────────
SEED_MENTOR_EMAIL=mentor@brightmango.in
SEED_MENTOR_NAME=BrightMango Mentor

# ── Mail (Resend) ───────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM="BrightMango <no-reply@brightmango.in>"

# ── Razorpay ────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Cloudflare R2 (files) ───────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=brightmango-assets
# Public base URL for the bucket (R2 custom domain or r2.dev URL).
# Required for profile-photo uploads — avatars are served publicly from
# ${R2_PUBLIC_BASE_URL}/avatars/... ; lesson resources stay presigned-only.
R2_PUBLIC_BASE_URL=

# ── Cloudflare Stream (video) ───────────────────────────
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
CF_STREAM_SIGNING_KEY_ID=
CF_STREAM_SIGNING_KEY_PEM=
